# ── Text-to-Speech ────────────────────────────────────────────────────────────
# TTS provider is selected in config.yaml (tts.provider).
# In "auto" mode, ElevenLabs is tried first, then OpenAI, then browser fallback.

# ElevenLabs — highest quality Japanese TTS
ELEVENLABS_API_KEY=

# OpenAI — fallback TTS (tts-1 / tts-1-hd)
OPENAI_API_KEY=

# ── Translation ───────────────────────────────────────────────────────────────
# Translation provider is selected in config.yaml (translation.provider).
# In "auto" mode, Ollama (local) is tried first, then Google Translate.
# Ollama requires no key — just a running local server (see translation.ollama in config.yaml).

# Google Cloud Translation API — fallback when Ollama is unavailable
GOOGLE_API_KEY=

# ── Publish — AWS S3 ─────────────────────────────────────────────────────────
# Used when publish.provider = s3 in config.yaml.
# If omitted, the SDK falls back to ~/.aws/credentials or an IAM instance role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ── Publish — Cloudflare R2 ───────────────────────────────────────────────────
# Used when publish.provider = r2 in config.yaml.
# Create an R2 API token at: Cloudflare dashboard → R2 → Manage R2 API tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to any non-empty value to print full error stack traces
DEBUG=
